# Identifiants de ton app, à récupérer sur https://developers.tiktok.com/apps
TIKTOK_CLIENT_KEY=colle_ta_client_key_ici
TIKTOK_CLIENT_SECRET=colle_ton_client_secret_ici

# Doit correspondre EXACTEMENT à l'URL de redirection déclarée dans ton app TikTok
TIKTOK_REDIRECT_URI=http://localhost:3000/auth/tiktok/callback

# Port du serveur local
PORT=3000

# Clé pour signer les cookies de session (mets une chaîne aléatoire longue)
SESSION_SECRET=change_moi_avec_une_valeur_aleatoire

# Clé API Anthropic, pour la génération de script IA (console.anthropic.com)
ANTHROPIC_API_KEY=colle_ta_cle_anthropic_ici
